{
  "name": "@fresh-feel/slots",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:prerender",
    "build:client": "tsc -b && vite build",
    "build:ssr": "vite build --ssr src/entry-ssr.tsx --outDir dist-ssr",
    "build:prerender": "npm run build:ssr && tsx scripts/prerender.mts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dicebear/big-smile": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@dicebear/lorelei": "^9.4.2",
    "@dicebear/notionists": "^9.4.2",
    "@dicebear/open-peeps": "^9.4.2",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fresh-feel/slotboard-core": "*",
    "@sentry/react": "^10.53.1",
    "lucide-react": "^1.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.22.0",
    "typescript": "^5.9.0",
    "vite": "^6.4.2"
  }
}
