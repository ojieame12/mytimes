{
  "name": "mytimes-booking",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:slots": "npm run dev --workspace @fresh-feel/slots",
    "dev:api": "npm run dev --workspace @fresh-feel/slots-api",
    "build:core": "npm run build --workspace @fresh-feel/slotboard-core",
    "typecheck": "npm run build:core && npm run typecheck --workspaces --if-present",
    "build": "npm run build:core && npm run build --workspaces --if-present",
    "test:api": "tsx scripts/test-api-concurrency-privacy.mjs",
    "test:hardening": "tsx scripts/test-api-hardening.mjs",
    "test:billing": "tsx scripts/test-billing-entitlements.mjs",
    "test:railway-domain": "tsx scripts/test-railway-custom-domain.mjs",
    "test:company-workspace": "tsx scripts/test-company-workspace.mjs",
    "test:auth-reset": "tsx scripts/test-auth-password-reset.mjs",
    "test:email": "tsx scripts/test-email-shape.mjs",
    "test:booking-ui": "node --import ./scripts/register-css-noop.mjs --import tsx scripts/test-booking-ui-regression.tsx",
    "test:admin-access-ui": "tsx scripts/test-admin-access-ui.tsx",
    "test:notification-integrations-ui": "tsx scripts/test-notification-integrations-ui.tsx",
    "test:observability": "tsx scripts/test-observability-ops.mjs",
    "test:booking-flow": "node --import ./scripts/register-css-noop.mjs --import tsx scripts/test-booking-flow-live.tsx",
    "test:frontend-readiness": "node scripts/test-frontend-readiness.mjs",
    "audit:pricing-promises": "node scripts/audit-pricing-promises.mjs",
    "test:pricing-promises": "node scripts/audit-pricing-promises.mjs --strict",
    "test:e2e": "npm run typecheck && npm run build && npm run test:email && npm run test:auth-reset && npm run test:billing && npm run test:railway-domain && npm run test:api && npm run test:hardening && npm run test:booking-ui && npm run test:admin-access-ui && npm run test:notification-integrations-ui && npm run test:observability && npm run test:booking-flow && npm run test:frontend-readiness",
    "auth:links": "node scripts/auth-links.mjs",
    "email:ready": "node scripts/email-readiness.mjs",
    "email:test": "node scripts/email-test.mjs",
    "observability:ready": "node scripts/observability-readiness.mjs",
    "observability:test": "node scripts/observability-test.mjs",
    "retention:ready": "node scripts/retention-readiness.mjs",
    "email:activate:resend": "node scripts/activate-resend-production.mjs",
    "billing:ready": "node scripts/billing-readiness.mjs",
    "billing:activate:stripe": "node scripts/activate-stripe-production.mjs",
    "custom-domain:activate": "node scripts/activate-custom-domain.mjs",
    "api-domain:ready": "node scripts/check-api-domain.mjs",
    "db:backup": "node scripts/db-backup.mjs",
    "db:backup:railway": "SLOTBOARD_BACKUP_SOURCE=railway node scripts/db-backup.mjs",
    "db:backup:railway:schema": "SLOTBOARD_BACKUP_SOURCE=railway SLOTBOARD_BACKUP_SCHEMA_ONLY=true node scripts/db-backup.mjs",
    "db:restore-check": "node scripts/db-restore-check.mjs",
    "retention": "npm run retention --workspace @fresh-feel/slots-api",
    "retention:prod": "npm run retention:prod --workspace @fresh-feel/slots-api",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "smoke:billing-live": "node scripts/smoke-billing-live.mjs",
    "smoke:retention": "node scripts/smoke-retention.mjs",
    "smoke:live": "node scripts/test-live-readiness.mjs",
    "security:ready": "node scripts/test-live-readiness.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.0"
  }
}
